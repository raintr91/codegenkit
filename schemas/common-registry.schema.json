{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/raintr91/codegenkit/schemas/common-registry.schema.json",
  "title": "Codegenkit common registry",
  "type": "object",
  "required": ["version", "entries", "aliasIndex"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "aliasIndex": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["status", "tag", "kind", "path", "summary", "usedBy", "specRefs"],
      "properties": {
        "status": {
          "enum": ["planned", "implemented", "deprecated"]
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "usedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}
