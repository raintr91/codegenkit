<?php

namespace {{moduleNamespace}}\Tests\Unit\Http\Resources;

use Illuminate\Http\Request;
use {{phpFqcn entityResourceFqcn}};
use {{phpFqcn modelFqcn}};
use Tests\Unit\Concerns\AssertsResourceOpenApiKeys;
use Tests\Unit\UnitTestCase;

class {{entity}}ResourceOpenApiShapeBehaviorTest extends UnitTestCase
{
    use AssertsResourceOpenApiKeys;

    public function test_resource_array_matches_openapi_keys(): void
    {
        $model = new {{phpFqcn modelFqcn}}();
        $model->forceFill(['id' => 1, 'name' => 'Spec Hotel']);

        if (method_exists($model, '{{nestedRelationKey}}')) {
            $model->setRelation('{{nestedRelationKey}}', collect());
        }

        $data = (new {{phpFqcn entityResourceFqcn}}($model))->toArray(Request::create('/admin-test', 'GET'));

        $this->assertResourceArrayHasKeys($data, {{phpStringArray openApiKeys}});
    }
}
