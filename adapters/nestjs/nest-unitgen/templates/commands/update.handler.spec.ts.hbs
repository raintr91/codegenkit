import { Update{{entityPascal}}Handler } from './update-{{entityKebab}}.handler'
import { Update{{entityPascal}}Command } from './update-{{entityKebab}}.command'
import { {{entityPascal}}Entity } from '../{{entityKebab}}.entity'
import { getRepositoryToken } from '@nestjs/typeorm'
import { Test } from '@nestjs/testing'

describe('Update{{entityPascal}}Handler', () => {
  const mockRepo = {
    create: jest.fn(),
    save: jest.fn(),
    update: jest.fn().mockResolvedValue({ affected: 1 }),
    delete: jest.fn(),
    findOneOrFail: jest.fn().mockResolvedValue({ id: 1, name: 'Updated' })
  }

  async function createHandler() {
    const moduleRef = await Test.createTestingModule({
      providers: [
        Update{{entityPascal}}Handler,
        { provide: getRepositoryToken({{entityPascal}}Entity), useValue: mockRepo }
      ]
    }).compile()
    return moduleRef.get(Update{{entityPascal}}Handler)
  }

  it('updates entity and returns dto', async () => {
    const handler = await createHandler()
    const result = await handler.execute(new Update{{entityPascal}}Command(1, { name: 'Updated' }))
    expect(result).toMatchObject({ id: 1, name: 'Updated' })
    expect(mockRepo.update).toHaveBeenCalled()
  })
})
