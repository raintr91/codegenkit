import { toTypedSchema } from '@vee-validate/zod'
import { z } from 'zod'

import { fields } from '~/models/common/fields'

export const {{entityCamel}}CreateObjectSchema = z.object({
{{#each formFieldSchemas}}
    {{key}}: {{{zodField}}},
{{/each}}
  })

export const {{entityCamel}}CreateSchema = toTypedSchema({{entityCamel}}CreateObjectSchema)
